# ======================================================================
# Party House — Server Node (backend completo)
# Copiar a .env y completar. NO subir al repositorio.
# ======================================================================
#
# El server Node es el backend real:
# captura pagos de PayPal, procesa transferencias (con upload + Telegram),
# emite JWT del QR, manda email con el ticket, valida QRs en la puerta
# y expone el panel admin. N8N queda solo con el bot admin para códigos.
# ======================================================================

# ---- Servidor ----
PORT=3000

# URL pública del server (usada en links de emails y mensajes Telegram).
# En dev: http://localhost:3000 — en prod: https://tudominio.com
PUBLIC_BASE_URL=http://localhost:3000

# ---- Supabase ----
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Bucket privado donde se suben las boletas de transferencia.
# Crealo desde Supabase Dashboard → Storage (privado, 5MB max).
RECEIPTS_BUCKET=receipts

# ---- Seguridad ----
# Generar con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# El server es el ÚNICO que firma/verifica JWT del QR.
JWT_SECRET=cambia-esto-por-un-string-aleatorio-largo

# PIN de acceso para el personal de puerta (PWA /validador.html)
# Se usa como fallback si el staff no tiene un registro en app_users.
STAFF_PIN=1234

# ---- PayPal ----
# Sandbox:  https://api-m.sandbox.paypal.com  (por defecto)
# Live:     https://api-m.paypal.com
PAYPAL_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ---- Transferencia manual ----
# WhatsApp (deprecado pero aún se expone en /api/public-config por compat).
# Con el nuevo flujo el invitado sube la boleta directo en la landing.
WHATSAPP_NUMBER=

# Texto con los datos bancarios que se renderiza en evento.html
BANK_DETAILS=Banco Ejemplo · Cuenta: 0000-0000-0000 · Titular: Party House SA

# ---- Telegram (notificaciones al admin) ----
# Token del mismo bot que usa N8N (@BotFather). El server lo usa para
# mandar sendPhoto al admin cuando llega una transferencia.
TELEGRAM_BOT_TOKEN=

# IDs de Telegram de los admins (coma-separados, sin espacios).
# Mínimo 1. Ej: 7360106479 o 7360106479,1234567890
ADMIN_TELEGRAM_IDS=

# ---- Email (SMTP propio — hosting / Roundcube) ----
# Datos del servidor SMTP que usa tu hosting. Roundcube es solo webmail;
# por detrás corre típicamente Postfix/Exim en puertos 465 (SSL) o 587 (STARTTLS).
#
# Ejemplos típicos (cPanel, Plesk, Hestia):
#   SMTP_HOST=mail.tudominio.com
#   SMTP_PORT=465         SMTP_SECURE=true   (SSL directo)
#   SMTP_PORT=587         SMTP_SECURE=false  (STARTTLS)
#
# SMTP_USER es el email completo; SMTP_PASS es la contraseña de esa cuenta.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Remitente visible. Si queda vacío, se usa SMTP_USER.
# Ej: Party House <no-reply@tudominio.com>
MAIL_FROM=
